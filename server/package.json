{
  "name": "book_lib",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc && node -e \"fs.cpSync('src', 'dist', { recursive: true, filter: (src) => src.endsWith('.graphql') || fs.statSync(src).isDirectory() })\"",
    "deploy-build": "npm run build && node -e \"['vercel.json', 'package.json'].forEach(f => fs.copyFileSync(f, 'dist/' + f))\"",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate": "graphql-codegen",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-resolvers": "^6.0.2",
    "@tsconfig/node22": "^22.0.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.1",
    "chalk": "5.6.2",
    "eslint": "^9.39.4",
    "eslint-plugin-perfectionist": "^5.9.1",
    "prettier": "^3.9.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express5": "^1.1.2",
    "@graphql-tools/load-files": "^7.0.1",
    "@graphql-tools/merge": "^9.1.10",
    "body-parser": "^2.3.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dataloader": "^2.2.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphql": "^16.14.2",
    "mongoose": "^9.7.3",
    "multer": "^2.2.0"
  },
  "overrides": {
    "@graphql-codegen/cli": {
      "shell-quote": "1.8.4"
    },
    "express": {
      "path-to-regexp": "8.4.2"
    },
    "eslint": {
      "flatted": "3.4.2",
      "minimatch": "3.1.5",
      "@eslint/config-array": {
        "minimatch": "3.1.5"
      },
      "@eslint/eslintrc": {
        "minimatch": "3.1.5"
      }
    },
    "picomatch": "^4.0.4"
  }
}
